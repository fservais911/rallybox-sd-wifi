{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Git: Create Snapshot Commit (main)",
			"type": "process",
			"command": "powershell.exe",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-File",
				"${workspaceFolder}\\.vscode\\scripts\\git_snapshot_main.ps1"
			],
			"problemMatcher": [],
			"group": "build"
		},
		{
			"label": "Git: Create Backup Branch From Main",
			"type": "process",
			"command": "powershell.exe",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-File",
				"${workspaceFolder}\\.vscode\\scripts\\git_backup_main.ps1"
			],
			"problemMatcher": [],
			"group": "build"
		},
		{
			"label": "Git: Restore Last Backup To Main",
			"type": "process",
			"command": "powershell.exe",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-File",
				"${workspaceFolder}\\.vscode\\scripts\\git_restore_last_backup_to_main.ps1"
			],
			"problemMatcher": [],
			"group": "build"
		}
	]
}